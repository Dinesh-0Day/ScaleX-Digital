  display: block;
  grid-area: 1 / 1;
  clip-path: inset(0% 0% 100% 0%);
 	translate: 0 -.25rem 0;
  scale: 1.05;
  transform-origin: top center;
}

.button_text {
  clip-path: inset(0% 0% 0% 0%);
 
  translate: 0 0 0;
