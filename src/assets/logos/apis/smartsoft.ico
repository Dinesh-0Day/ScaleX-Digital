<script src="https://unpkg.com/lenis@1.1.9/dist/lenis.min.js"></script> 

<script>
// Notices
let acceptedNotices = JSON.parse(localStorage.getItem('notices-accepted')) || [];
// Remove accepted notices
if (acceptedNotices.length > 0) {
	acceptedNotices.forEach(function(type) {
  	const notice = $('.notices_item[data-notice="'+type+'"]'),
    			siblings = notice.siblings('.notices_item')

    if (siblings.length > 0) {
   		siblings.eq(0).addClass('is-active')
    } else {
    	$('.notices').remove()
    }
  	notice.remove()
  })
}

if ($('.notices').length > 0) {
	$('.notices').css('display', 'flex')

  // Close notice, add it to localStorage
  $('.notices_item').find('[data-action="close"]').click(function() {
    const thisItem = $(this).parents('.notices_item'),
          type = thisItem.data('notice')

    acceptedNotices.push(type)

    localStorage.setItem('notices-accepted', JSON.stringify(acceptedNotices))

    $('.notices_item').removeClass('is-active')
    thisItem.addClass('is-away')
    thisItem.next().addClass('is-active')
    setTimeout(function() {
      thisItem.hide()

      if ($('.notices_item.is-active').length === 0) {
        $('.notices').css('opacity', '0')
        setTimeout(function() {
          $('.notices').hide()
        }, 300)
      }
    }, 600)
  })
}

// Define the letters and symbols for the random text animation
const lettersAndSymbols = ['a', 'b', 'c', 'd', 'e', 'f', 'g', 'h', 'i', 'j', 'k', 'l', 'm', 'n', 'o', 'p', 'q', 'r', 's', 't', 'u', 'v', 'w', 'x', 'y', 'z', '!', '@', '#', '$', '%', '^', '&', '*', '-', '_', '+', '=', ';', ':', '<', '>', ','];

// TextSplitter class definition
class TextSplitter {
  constructor(element, options) {
    this.element = element;
    this.options = options;
    this.chars = this.split();
  }

  split() {
    const { splitTypeTypes } = this.options;
    let splitChars = [];

    if (splitTypeTypes.includes('words')) {
      const words = this.element.innerText.split(' ');
      this.element.innerHTML = words.map(word => `<span class="word">${word}</span>`).join(' ');
      splitChars = Array.from(this.element.querySelectorAll('.word'));
    }
    if (splitTypeTypes.includes('chars')) {
      splitChars = splitChars.flatMap(word => {
        const chars = word.innerText.split('').map(char => `<span class="char">${char}</span>`).join('');
        word.innerHTML = chars;
        return Array.from(word.querySelectorAll('.char'));
      });
    }
    return splitChars;
  }

  getChars() {
    return this.chars;
  }
}

// TextAnimator class definition
class TextAnimator {
  constructor(textElement) {
    if (!textElement || !(textElement instanceof HTMLElement)) {
      throw new Error('Invalid text element provided.');
    }

    this.textElement = textElement;
    this.splitText();
  }

  splitText() {
    this.splitter = new TextSplitter(this.textElement, {
      splitTypeTypes: 'words, chars'
    });

    this.originalChars = this.splitter.getChars().map(char => char.innerHTML);
  }

  animate() {
    this.reset();

    const chars = this.splitter.getChars();
    chars.forEach((char, position) => {
      let initialHTML = char.innerHTML;
      let repeatCount = 0;

      gsap.fromTo(char, {
        opacity: 0
      },
      {
        duration: 0.02,
        onStart: () => {
          gsap.set(char, { '--opa': 1 });
        },
        onComplete: () => {
          gsap.set(char, { innerHTML: initialHTML, delay: 0.02 })
        },
        repeat: 3,
        onRepeat: () => {
          repeatCount++;
          if (repeatCount === 1) {
            gsap.set(char, { '--opa': 0 });
          }
        },
        repeatRefresh: true,
        repeatDelay: 0.027,
        delay: (position + 1) * 0.047,
        innerHTML: () => lettersAndSymbols[Math.floor(Math.random() * lettersAndSymbols.length)],
        opacity: 1
      });
    });
  }
  
  reset() {
    const chars = this.splitter.getChars();
    chars.forEach((char, index) => {
      gsap.killTweensOf(char); // Ensure no ongoing animations
      char.innerHTML = this.originalChars[index];
    });
  }
}

const isDesktop = function() { return window.matchMedia('(min-width: 992px)').matches }
const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth
const isHome = window.location.pathname === '/' || window.location.pathname === ''
const hideLoaderDuration = 2000
let isDesktopInitial = isDesktop()

// Rewrite CSS variables
const updateVars = function() {
  $(':root').css('--screen-inner-width', document.documentElement.clientWidth + "px")
}

updateVars()

$(window).resize(function() {
  let newIsDesktop = window.matchMedia('(min-width: 992px)').matches;
  if (newIsDesktop !== isDesktopInitial) {
    location.reload(); // Reload on change between desktop and tablet
  }
  isDesktopInitial = newIsDesktop;
  updateVars()
})

// Smooth scroll
const lenis = new Lenis()

function raf(time) {
  lenis.raf(time)
  requestAnimationFrame(raf)
}

requestAnimationFrame(raf)

// Disable/enable scroll
let isScrollDisabled = false
$('.scrollbar-space').css('width', scrollbarWidth)
  
const disableScroll = function() {
  lenis.stop()
  if (isDesktop()) {
    $('body, .header_main').css('margin-right', scrollbarWidth + 'px')
    $('.scrollbar-space').show()
  }
  isScrollDisabled = true
}

const enableScroll = function() {
  lenis.start()
  if (isDesktop()) {
    $('body, .header_main').css('margin-right', '0')
    $('.scrollbar-space').hide()
  }
  isScrollDisabled = false
}
  
// Menu button
$('.header_menu-button').click(function(){
  // Disable/enable scroll
  if (isScrollDisabled) {
  	enableScroll()
    $(this).attr('aria-expanded', 'false')
    $('.header_wrapper').removeClass('text-color-white')
  } else {
  	disableScroll()
    $(this).attr('aria-expanded', 'true')
    $('.header_wrapper').addClass('text-color-white')
  }
})

// Adaptive text area
$('textarea').each(function() {
    $(this).on('input', function() {
        $(this).height('auto') // Reset height to auto to recalculate scrollHeight
        $(this).height(this.scrollHeight - 21) // Set the height based on the new scrollHeight
    })
})

// Button hover text
$('.button_inner').each(function() {
	$(this).attr('data-text', $(this).find('.button_text').text())
})


// Function to load scripts dynamically
function loadScript(src, integrity = null, crossorigin = null) {
  return new Promise((resolve, reject) => {
    const script = document.createElement('script');
    script.src = src;
    script.async = true;
    if (integrity) script.integrity = integrity;
    if (crossorigin) script.crossOrigin = crossorigin;
    
    script.onload = resolve;
    script.onerror = reject;
    
    document.body.appendChild(script);
  });
}

// Function to load scripts
function loadDesktopScripts() {
  return Promise.all([
    loadScript('https://unpkg.com/split-type'),
    loadScript(
      'https://cdnjs.cloudflare.com/ajax/libs/split.js/1.6.2/split.min.js',
      'sha512-to2k78YjoNUq8+hnJS8AwFg/nrLRFLdYYalb18SlcsFRXavCOTfBF3lNyplKkLJeB8YjKVTb1FPHGSy9sXfSdg==',
      'anonymous'
    ),
    loadScript(
      'https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js',
      'sha512-7eHRwcbYkK4d9g/6tD/mhkf++eoTHwpNM9woBxtPUBWm67zeAfFC+HrdoE2GanKeocly/VxeLvIqwvCdk7qScg==',
      'anonymous'
    )
  ]);
}

function letterHoverEffect() {
  // Initialize the text animation on hover
  const init = () => {
  	// Links
    document.querySelectorAll('[data-hover-letters]').forEach(item => {
      const animator = new TextAnimator(item);
      item.addEventListener('mouseenter', () => {
        animator.animate();
      });
    });
  };

  init();
}

$('[data-hover-letters], [data-loading-text], [data-loading-text-mobile]').each(function() {
  const width = $(this).width()
  $(this).attr('data-width', width)
})
  
function initialWordWidth() {
	$('[data-hover-letters], [data-loading-text], [data-loading-text-mobile]').each(function() {
    $(this).css('width', $(this).attr('data-width'))
  })
}

function updateWordWidth() {
	$('[data-hover-letters], [data-loading-text], [data-loading-text-mobile]').each(function() {
    $(this).removeAttr('style')
    $(this).css('width', $(this).width())
  })
}


function startLetterHoverEffect() {
  loadDesktopScripts()
    .then(() => {
      letterHoverEffect();
      initialWordWidth();
    })
    .catch(error => {
      console.error('Error loading scripts:', error);
    });
}

// Start only on desktop
if (isDesktop()) {
	startLetterHoverEffect()
} else {
	// Fix mobile loader text width
	$('[data-loading-text-mobile]').each(function() {
    $(this).css('width', $(this).attr('data-width'))
  })
}

$(window).resize(function() {
	updateWordWidth()
})

// Global variables
let dotsInterval = null;

// Page loader
let hideLoader = function() {
  $('.loader_inner').addClass('is-active')
  $('.page-wrapper, .scroll_link').css({opacity: '1'})
  $('[data-top-section], [data-second-section]').css('transform', 'translateY(0vh) rotate(0deg)')
  $('.header_wrapper, .section_home-hero, .section_home-second, .scroll_link, .spaceship_wrapper').removeClass('is-initial')

  // Force scroll to top
  const scrollToTop = function() {
    window.scrollTo(0, 0);
    $(window).scrollTop(1);
    setTimeout(function() {
    	$(window).scrollTop(0);
    }, 100)
  }
  
  scrollToTop()

  // Enable scroll after loader is hidden
  setTimeout(function() {
    $('.loader_wrapper').hide()
    $(window).scrollTop(1);
    enableScroll();
    // Clear interval after loader is fully hidden
    if (dotsInterval) {
      clearInterval(dotsInterval)
      dotsInterval = null
    }
  }, hideLoaderDuration)
}
  
const pageLoad = function() {
  const spaceship = $('.spaceship');
  const loaderStartTime = Date.now();
  const minLoaderDuration = isHome ? 2000 : 0; // Minimum loader display time
  
  // Disable scroll during page load
  disableScroll();
  
  // Initial scroll to top
  window.location.hash = '';
  window.scrollTo(0, 0);
  
  // Initial state for exit loader
  $('.exit-loader_wrapper').removeClass('is-active').hide()
  
  // Page transition - IN animation
  // Initial states
  $('.loader_inner').removeClass('is-active')
  $('.header_wrapper, .section_home-hero, .section_home-second, .scroll_link, .spaceship_wrapper').addClass('is-initial')
  
  // Load required scripts and start animations
  if (isDesktop()) {
  loadDesktopScripts()
    .then(() => {
      // Start loader text animation
      if (isHome) {
        document.querySelectorAll('[data-loading-text]').forEach(item => {
          const animator = new TextAnimator(item);

          $('.loader_inner').css('opacity', '1');
          setTimeout(function() {
            animator.animate();
          }, 300)
          // Dots animation
          setTimeout(function() {
            dotsInterval = setInterval(function() {
              const chars = $('[data-loading-text] .char');
              let dot1Index = chars.length - 2;
              let dot2Index = chars.length - 1;

              let dot1Visible = chars.eq(dot1Index).css('opacity') == 1;
              let dot2Visible = chars.eq(dot2Index).css('opacity') == 1;

              if (dot1Visible && dot2Visible) {
                chars.eq(dot1Index).css('opacity', 0);
                chars.eq(dot2Index).css('opacity', 0);
              } else if (!dot1Visible && !dot2Visible) {
                chars.eq(dot1Index).css('opacity', 1);
              } else if (dot1Visible && !dot2Visible) {
                chars.eq(dot2Index).css('opacity', 1);
              }
            }, 150);
          }, 1000);
        });
      }
    })
    .catch(error => {
      console.error('Error loading scripts:', error);
    });
  }
  
  // Waiting for spline 
  if (spaceship.length && isDesktop()) {
  	const canvas = spaceship.find('canvas');
    if (canvas.length) {
      // Use MutationObserver to track changes to the style attribute
      const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
          if (mutation.type === 'attributes' && mutation.attributeName === 'style') {
            observer.disconnect(); // Disconnect the observer
            const elapsedTime = Date.now() - loaderStartTime;
            const remainingTime = Math.max(0, minLoaderDuration - elapsedTime);

            setTimeout(() => {
              hideLoader();
            }, remainingTime);
          }
        });
      });

      // Observe changes to the style attribute on canvas
      observer.observe(canvas[0], { attributes: true, attributeFilter: ['style'] });

      // Check if the style attribute is already present
      if (canvas.attr('style')) {
        console.log('Style attribute already present on canvas:', canvas.attr('style'));
        observer.disconnect(); // Disconnect the observer if style is already present
        const elapsedTime = Date.now() - loaderStartTime;
        const remainingTime = Math.max(0, minLoaderDuration - elapsedTime);

        setTimeout(() => {
          hideLoader();
        }, remainingTime);
      }
    } else {
      setTimeout(hideLoader, minLoaderDuration);
    }
  } else {
    // If mobile or spaceship is not found, show loader for minimum time
    setTimeout(hideLoader, minLoaderDuration);
  }
  
  // Mobile - dots animation
  if (!isDesktop() && isHome) {
    dotsInterval = setInterval(function() {
      const loaderDots = $('[data-loading-dots]');
      let loaderDotsText = loaderDots.text();

      if (loaderDotsText === '...') {
        loaderDots.text('.');
      } else if (loaderDotsText === '.') {
        loaderDots.text('..');
      } else {
        loaderDots.text('...');
      }
    }, 150);
  }
}

pageLoad()

// Page transition - exit
$(document).ready(function() {
  let internalLinks = $('a').filter(function() {
      let href = $(this).attr('href');
      return href &&
          (href.startsWith('/') || href.startsWith(window.location.origin)) &&
          !href.match(/\.(pdf|jpg|png|zip|docx?)$/i) &&
          !href.startsWith('#') && !$(this).is('[data-no-loader]');
  })
	
  internalLinks.click(function(e) {
  	e.preventDefault()
    const page = $(this).attr('href')
    $('.exit-loader_wrapper').css('display', 'flex')
    setTimeout(function() {
    	$('.exit-loader_wrapper').addClass('is-active')
      $('.page-wrapper').css('opacity', '0')
    }, 100)
    setTimeout(function() {
    	window.location.href = page
    }, 1500)
  })

})

// If user returned to the page
$(window).on('pageshow', function(event) {
  if (event.originalEvent.persisted) {
    location.reload();
  }
})

// Function to animate elements when they enter or exit the viewport
function onVisible(element, onEnterCallback, onExitCallback, enterThreshold = 0.3, exitThreshold = 0.1) {
    // Create a single observer for all elements
    if (!window.intersectionObserver) {
        window.intersectionObserver = new IntersectionObserver((entries) => {
            const currentScrollTop = window.scrollY || document.documentElement.scrollTop;
            const scrollDirection = currentScrollTop > (window.lastScrollTop || 0) ? 'down' : 'up';
            window.lastScrollTop = currentScrollTop;

            entries.forEach(entry => {
                const target = entry.target;
                const wasVisible = target._wasVisible || false;
                const isVisible = entry.isIntersecting && entry.intersectionRatio >= enterThreshold;
                
                const callbackData = {
                    element: target,
                    direction: scrollDirection,
                    intersectionRatio: entry.intersectionRatio
                };

                // Element enters viewport
                if (isVisible && !wasVisible) {
                    if (typeof target._onEnter === 'function') {
                        target._onEnter(callbackData);
                    }
                } 
                // Element exits viewport
                else if (!entry.isIntersecting || entry.intersectionRatio < exitThreshold) {
                    if (wasVisible && typeof target._onExit === 'function') {
                        target._onExit(callbackData);
                    }
                }

                // Update visibility state
                target._wasVisible = isVisible;
            });
        }, { 
            threshold: [exitThreshold, enterThreshold],
            rootMargin: '50px' // Add margin for preloading
        });
    }

    // Observe each element
    $(element).each(function() {
        const target = this;
        target._onEnter = onEnterCallback;
        target._onExit = onExitCallback;
        target._wasVisible = false;
        window.intersectionObserver.observe(target);
    });
}

// Function to stop observing elements
function unobserveElements(elements) {
    if (window.intersectionObserver) {
        $(elements).each(function() {
            window.intersectionObserver.unobserve(this);
            delete this._onEnter;
            delete this._onExit;
            delete this._wasVisible;
        });
    }
}
</script></body></html>